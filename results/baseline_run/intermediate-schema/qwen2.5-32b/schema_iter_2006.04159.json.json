{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Scientific Acknowledgment Schema",
    "description": "A JSON schema for extracting and representing acknowledgments in scientific publications.",
    "type": "object",
    "properties": {
        "acknowledgments": {
            "type": "array",
            "description": "An array of acknowledgment entries.",
            "items": {
                "type": "object",
                "properties": {
                    "individualsAcknowledged": {
                        "type": "array",
                        "description": "Individuals acknowledged for their contributions to the research, including reviewers and other contributors.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "The name of the individual being acknowledged."
                                },
                                "role": {
                                    "type": "string",
                                    "description": "The role or contribution of the individual in the research.",
                                    "enum": [
                                        "discussion",
                                        "feedback",
                                        "code",
                                        "visualization",
                                        "data_preparation",
                                        "error_correction",
                                        "insightful_comments",
                                        "support",
                                        "help",
                                        "cooperation",
                                        "comments",
                                        "suggestions"
                                    ]
                                }
                            },
                            "required": [
                                "name",
                                "role"
                            ]
                        }
                    },
                    "fundingSources": {
                        "type": "array",
                        "description": "Funding sources supporting the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "sourceName": {
                                    "type": "string",
                                    "description": "The name of the funding source."
                                },
                                "grantNumbers": {
                                    "type": "array",
                                    "description": "An array of grant numbers or identifiers provided by the funding source, if applicable.",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "contributionType": {
                                    "type": "string",
                                    "description": "The type of contribution from the funding source (e.g., cash or in-kind).",
                                    "enum": [
                                        "cash",
                                        "in_kind"
                                    ]
                                }
                            },
                            "required": [
                                "sourceName"
                            ]
                        }
                    },
                    "researchInitiativesAcknowledged": {
                        "type": "array",
                        "description": "Research initiatives acknowledged for their contributions to the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "initiativeName": {
                                    "type": "string",
                                    "description": "The name of the research initiative."
                                },
                                "details": {
                                    "type": "string",
                                    "description": "Details about the research initiative, such as objectives or scope."
                                }
                            },
                            "required": [
                                "initiativeName"
                            ]
                        }
                    },
                    "institutionalSupportAcknowledged": {
                        "type": "array",
                        "description": "Institutional support acknowledged for their contributions to the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "supportType": {
                                    "type": "string",
                                    "description": "The type of institutional support provided."
                                },
                                "institutionName": {
                                    "type": "string",
                                    "description": "The name of the institution providing the support."
                                }
                            },
                            "required": [
                                "supportType"
                            ]
                        }
                    },
                    "computeResourcesAcknowledged": {
                        "type": "array",
                        "description": "Compute resources acknowledged for their contributions to the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "resourceName": {
                                    "type": "string",
                                    "description": "The name of the compute resource."
                                },
                                "provider": {
                                    "type": "string",
                                    "description": "The provider or organization managing the compute resource."
                                }
                            },
                            "required": [
                                "resourceName"
                            ]
                        }
                    },
                    "additionalAcknowledgments": {
                        "type": "array",
                        "description": "Additional acknowledgments that do not fit into predefined categories.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "category": {
                                    "type": "string",
                                    "description": "The category of the acknowledgment."
                                },
                                "details": {
                                    "type": "string",
                                    "description": "Details about the acknowledgment, such as names or descriptions."
                                }
                            },
                            "required": [
                                "category"
                            ]
                        }
                    },
                    "governmentAcknowledgment": {
                        "type": "object",
                        "properties": {
                            "agencyName": {
                                "type": "string",
                                "description": "The name of the government agency providing support."
                            },
                            "contractDetails": {
                                "type": "string",
                                "description": "Contract details, including contract number and any additional information."
                            },
                            "disclaimer": {
                                "type": "string",
                                "description": "A disclaimer statement regarding the views and conclusions contained in the publication."
                            }
                        },
                        "required": [
                            "agencyName"
                        ]
                    }
                },
                "required": [
                    "individualsAcknowledged",
                    "fundingSources",
                    "governmentAcknowledgment"
                ]
            }
        }
    },
    "required": [
        "acknowledgments"
    ]
}