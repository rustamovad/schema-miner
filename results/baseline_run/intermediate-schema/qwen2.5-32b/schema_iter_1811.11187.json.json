{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Scientific Acknowledgment Schema",
    "description": "A JSON schema for extracting and representing acknowledgments in scientific publications.",
    "type": "object",
    "properties": {
        "acknowledgments": {
            "type": "array",
            "description": "An array of acknowledgment entries.",
            "items": {
                "type": "object",
                "properties": {
                    "individualsAcknowledged": {
                        "type": "array",
                        "description": "Individuals acknowledged for their contributions to the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "The name of the individual being acknowledged."
                                },
                                "role": {
                                    "type": "string",
                                    "description": "The role or contribution of the individual in the research.",
                                    "enum": [
                                        "discussion",
                                        "feedback",
                                        "code",
                                        "visualization",
                                        "data_preparation",
                                        "error_correction",
                                        "insightful_comments",
                                        "support",
                                        "help",
                                        "cooperation",
                                        "comments",
                                        "suggestions"
                                    ]
                                }
                            },
                            "required": [
                                "name",
                                "role"
                            ]
                        }
                    },
                    "fundingSources": {
                        "type": "array",
                        "description": "Funding sources supporting the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "sourceName": {
                                    "type": "string",
                                    "description": "The name of the funding source."
                                },
                                "grantNumber": {
                                    "type": "string",
                                    "description": "The grant number or identifier provided by the funding source, if applicable."
                                }
                            },
                            "required": [
                                "sourceName"
                            ]
                        }
                    },
                    "datasetsAcknowledged": {
                        "type": "array",
                        "description": "Datasets acknowledged for their contributions to the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "datasetName": {
                                    "type": "string",
                                    "description": "The name of the dataset."
                                },
                                "provider": {
                                    "type": "string",
                                    "description": "The provider or organization managing the dataset."
                                }
                            },
                            "required": [
                                "datasetName",
                                "provider"
                            ]
                        }
                    },
                    "awardsAndFellowships": {
                        "type": "array",
                        "description": "Awards and fellowships acknowledged for their contributions to the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "awardOrFellowshipName": {
                                    "type": "string",
                                    "description": "The name of the award or fellowship."
                                },
                                "grantNumber": {
                                    "type": "string",
                                    "description": "The grant number or identifier provided by the funding source, if applicable."
                                }
                            },
                            "required": [
                                "awardOrFellowshipName"
                            ]
                        }
                    }
                },
                "required": [
                    "individualsAcknowledged",
                    "fundingSources"
                ]
            }
        }
    },
    "required": [
        "acknowledgments"
    ]
}