{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Scientific Acknowledgment Schema",
    "description": "A JSON schema for extracting and representing acknowledgments in scientific publications.",
    "type": "object",
    "properties": {
        "acknowledgments": {
            "type": "array",
            "description": "An array of acknowledgment entries.",
            "items": {
                "type": "object",
                "properties": {
                    "acknowledges": {
                        "type": "array",
                        "description": "Entities being acknowledged, including their roles and contributions.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "entity": {
                                    "type": "string",
                                    "description": "The name or identifier of the entity being acknowledged."
                                },
                                "role": {
                                    "type": "string",
                                    "description": "The role or contribution of the entity in the research.",
                                    "enum": [
                                        "discussion",
                                        "feedback",
                                        "code",
                                        "visualization",
                                        "data_preparation",
                                        "error_correction",
                                        "insightful_comments",
                                        "support",
                                        "help",
                                        "cooperation",
                                        "comments",
                                        "suggestions",
                                        "organizing_event",
                                        "financial_support"
                                    ]
                                },
                                "contribution": {
                                    "type": "string",
                                    "description": "Specific contributions made by the entity, such as providing model outputs for error analysis."
                                }
                            },
                            "required": [
                                "entity",
                                "role"
                            ]
                        }
                    },
                    "funding": {
                        "type": "array",
                        "description": "Funding sources supporting the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "fundingBody": {
                                    "type": "string",
                                    "description": "The name of the funding body or organization."
                                },
                                "grantNumber": {
                                    "type": "string",
                                    "description": "The grant number or identifier provided by the funding body."
                                }
                            },
                            "required": [
                                "fundingBody"
                            ]
                        }
                    },
                    "internship_details": {
                        "type": "object",
                        "description": "Details of internships mentioned in acknowledgments.",
                        "properties": {
                            "internName": {
                                "type": "string",
                                "description": "The name of the individual who was an intern."
                            },
                            "company": {
                                "type": "string",
                                "description": "The company or organization where the internship took place."
                            }
                        },
                        "required": [
                            "internName",
                            "company"
                        ]
                    },
                    "resources": {
                        "type": "array",
                        "description": "Resources used in the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "resourceName": {
                                    "type": "string",
                                    "description": "The name of the resource."
                                },
                                "resourceType": {
                                    "type": "string",
                                    "description": "The type of resource (e.g., computing cluster, testbed)."
                                },
                                "provider": {
                                    "type": "string",
                                    "description": "The provider or organization managing the resource."
                                }
                            },
                            "required": [
                                "resourceName",
                                "resourceType",
                                "provider"
                            ]
                        }
                    },
                    "hardware_donations": {
                        "type": "array",
                        "description": "Hardware donations supporting the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "donor": {
                                    "type": "string",
                                    "description": "The name of the donor or organization providing the hardware."
                                },
                                "hardware": {
                                    "type": "string",
                                    "description": "The type or model of the donated hardware."
                                }
                            },
                            "required": [
                                "donor",
                                "hardware"
                            ]
                        }
                    },
                    "datasets": {
                        "type": "array",
                        "description": "Datasets used in the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "datasetName": {
                                    "type": "string",
                                    "description": "The name of the dataset."
                                },
                                "datasetProvider": {
                                    "type": "string",
                                    "description": "The provider or organization managing the dataset."
                                }
                            },
                            "required": [
                                "datasetName",
                                "datasetProvider"
                            ]
                        }
                    },
                    "grants_and_awards": {
                        "type": "array",
                        "description": "Grants and awards received by individuals involved in the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "recipient": {
                                    "type": "string",
                                    "description": "The name of the individual receiving the grant or award."
                                },
                                "grantAwardName": {
                                    "type": "string",
                                    "description": "The name of the grant or award."
                                }
                            },
                            "required": [
                                "recipient",
                                "grantAwardName"
                            ]
                        }
                    },
                    "software_used": {
                        "type": "array",
                        "description": "Software used in the research.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "softwareName": {
                                    "type": "string",
                                    "description": "The name of the software."
                                },
                                "version": {
                                    "type": "string",
                                    "description": "The version number or identifier of the software used."
                                }
                            },
                            "required": [
                                "softwareName"
                            ]
                        }
                    },
                    "additional_funding_sources": {
                        "type": "array",
                        "description": "Additional funding sources not covered by grants.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "sourceName": {
                                    "type": "string",
                                    "description": "The name of the additional funding source."
                                },
                                "grantNumber": {
                                    "type": "string",
                                    "description": "The grant number or identifier provided by the additional funding source, if applicable."
                                }
                            },
                            "required": [
                                "sourceName"
                            ]
                        }
                    },
                    "teamAcknowledgments": {
                        "type": "array",
                        "description": "Acknowledgment entries for teams or groups.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "groupName": {
                                    "type": "string",
                                    "description": "The name of the team or group being acknowledged."
                                },
                                "members": {
                                    "type": "array",
                                    "description": "Individual members within the team.",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "memberName": {
                                                "type": "string",
                                                "description": "The name of an individual member."
                                            },
                                            "role": {
                                                "type": "string",
                                                "description": "The role or contribution of the individual in the research.",
                                                "enum": [
                                                    "discussion",
                                                    "feedback",
                                                    "code",
                                                    "visualization",
                                                    "data_preparation",
                                                    "error_correction",
                                                    "insightful_comments",
                                                    "support",
                                                    "help",
                                                    "cooperation",
                                                    "comments",
                                                    "suggestions"
                                                ]
                                            }
                                        },
                                        "required": [
                                            "memberName",
                                            "role"
                                        ]
                                    }
                                }
                            },
                            "required": [
                                "groupName",
                                "members"
                            ]
                        }
                    }
                },
                "required": [
                    "acknowledges"
                ]
            }
        }
    },
    "required": [
        "acknowledgments"
    ]
}